# =============================================================================
# GSNet Portable Container -> !!!!!!This is specifically for the PC in the Robot Lab otherwise use the other dockerfile
# =============================================================================
# STRATEGY: Use CUDA 11.8 base for maximum driver compatibility
#
# CUDA 11.8 is supported by drivers 450.80.02+ (from ~2020 onwards)
# This means the container will work on virtually any modern NVIDIA GPU setup.
#
# Driver compatibility table:
#   - Driver 450.x+ → CUDA 11.0-11.8 ✓
#   - Driver 520.x+ → CUDA 11.8, 12.0 ✓  
#   - Driver 535.x+ → CUDA 11.8, 12.0-12.2 ✓
#   - Driver 550.x+ → CUDA 11.8, 12.0-12.4 ✓
#
# IMPORTANT: CUDA forward compatibility (using newer toolkit than driver supports)
# only works on datacenter GPUs (Tesla, A100, H100), NOT consumer GPUs (GeForce).
# =============================================================================

FROM pytorch/pytorch:2.1.0-cuda11.8-cudnn8-devel

ARG DEBIAN_FRONTEND=noninteractive
ARG TZ=Europe/Berlin
ENV TZ=${TZ}

# Ensure CUDA-based extensions are compiled even if no GPUs are visible during docker build
ENV CUDA_HOME=/usr/local/cuda
ENV FORCE_CUDA=1

# Architectures to compile CUDA extensions for:
# 6.1 = Pascal (GTX 1080, etc.)
# 7.0 = Volta (V100)
# 7.5 = Turing (RTX 2080 Ti, T4)
# 8.0 = Ampere (A100)
# 8.6 = Ampere consumer (RTX 3090)
# 8.9 = Ada Lovelace (RTX 4090)
# 9.0 = Hopper (H100) - requires CUDA 11.8+
ENV TORCH_CUDA_ARCH_LIST="6.1;7.0;7.5;8.0;8.6;8.9;9.0"

# Cache dir (rw for everyone to avoid permission issues with mounted volumes/CI)
ENV XDG_CACHE_HOME=/opt/cache

# =============================================================================
# CRITICAL: Remove CUDA forward compatibility libraries if present
# These cause "Error 804" on consumer GPUs (GeForce) when the container
# CUDA version is newer than what the host driver supports.
# =============================================================================
RUN rm -f /etc/ld.so.conf.d/*compat*.conf 2>/dev/null; ldconfig || true

# System deps (toolchain, OpenCV, and common headers some builds require)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git build-essential cmake ninja-build python3-opencv tzdata \
    pkg-config libjpeg-dev zlib1g-dev \
 && ln -fs /usr/share/zoneinfo/${TZ} /etc/localtime \
 && dpkg-reconfigure -f noninteractive tzdata \
 && rm -rf /var/lib/apt/lists/*

# Python build tooling for native/CUDA extensions
RUN python -m pip install --no-cache-dir --upgrade \
      pip \
      "setuptools<75" \
      wheel \
      cmake \
      ninja \
      packaging \
      "scikit-build-core>=0.10"

# =============================================================================
# CRITICAL: Force numpy 1.x FIRST before any other packages
# PyTorch 2.1.x was compiled against numpy 1.x and will fail with numpy 2.x
# We install numpy separately and use --no-deps where needed to prevent upgrades
# =============================================================================
RUN pip install --no-cache-dir --force-reinstall "numpy>=1.24,<1.27"

# Core Python deps (installed after numpy to prevent numpy upgrade)
RUN pip install --no-cache-dir \
      "scipy>=1.11,<1.14" \
      "tqdm>=4.65,<5" \
      "tensorboard>=2.14,<2.18" \
      "protobuf>=4,<5" \
      "fvcore>=0.1.5,<0.2" \
      "iopath>=0.1.10,<0.2"

# spconv: use cu118 wheel to match PyTorch CUDA version
# IMPORTANT: spconv CUDA version MUST match PyTorch CUDA version
RUN pip install --no-cache-dir "spconv-cu118>=2.3,<2.5"

# Verify numpy version is still 1.x (fail build if upgraded)
RUN python -c "import numpy; v=numpy.__version__; assert v.startswith('1.'), f'numpy upgraded to {v}'"

# trimesh for stable score computation (COG calculation)
# RUN pip install --no-cache-dir "trimesh>=4.0,<5"

# Extra runtime deps (matplotlib, zmq, plotly)
RUN pip install --no-cache-dir matplotlib pyzmq plotly

# Install graspnetAPI from local source
COPY graspnetAPI /tmp/graspnetAPI
RUN pip install --no-cache-dir /tmp/graspnetAPI && rm -rf /tmp/graspnetAPI

# Prepare cache dir with open permissions
RUN mkdir -p /opt/cache && chmod -R 777 /opt/cache

WORKDIR /workspace
